{
  "expo": {
    "name": "Thirakkundo",
    "slug": "railway-station-finder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Logo.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to find nearby railway stations.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We need your location to continuously track nearby railway stations.",
        "NSLocationAlwaysUsageDescription": "We need your location to track nearby railway stations in the background."
      }
    },
    "android": {
      "package": "com.trainproject.stationfinder",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/Logo.png",
        "backgroundColor": "#09090b"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Thirakkundo to use your location to find nearby stations."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bb837041-12c5-4b81-8793-3eac5ef144c2"
      }
    },
    "owner": "nithin_das",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bb837041-12c5-4b81-8793-3eac5ef144c2"
    }
  }
}
